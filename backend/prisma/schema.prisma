generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String   @map("senha_hash")
  criadoEm DateTime @default(now()) @map("criado_em")
  ativo     Boolean  @default(true)

  perfil        Perfil?
  vagas         Vaga[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  criadoEm DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Perfil {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  nome         String
  email        String
  telefone     String?
  cidade       String?
  linkedin     String?
  github       String?
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       Skill[]
  experiencias Experiencia[]
  projetos     Projeto[]
  formacoes    Formacao[]

  @@map("perfis")
}

model Skill {
  id        String @id @default(cuid())
  perfilId  String @map("perfil_id")
  nome      String
  categoria String
  nivel     String @default("intermediario")
  ordem     Int    @default(0)

  perfil Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Experiencia {
  id            String    @id @default(cuid())
  perfilId      String    @map("perfil_id")
  cargo         String
  empresa       String
  periodoInicio DateTime  @map("periodo_inicio")
  periodoFim    DateTime? @map("periodo_fim")
  atual         Boolean   @default(false)
  descricao     String?
  tecnologias   String[]
  ordem         Int       @default(0)

  perfil Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@map("experiencias")
}

model Projeto {
  id          String   @id @default(cuid())
  perfilId    String   @map("perfil_id")
  nome        String
  descricao   String?
  link        String?
  tecnologias String[]
  ordem       Int      @default(0)

  perfil Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@map("projetos")
}

model Formacao {
  id            String    @id @default(cuid())
  perfilId      String    @map("perfil_id")
  curso         String
  instituicao   String
  periodoInicio DateTime? @map("periodo_inicio")
  periodoFim    DateTime? @map("periodo_fim")
  atual         Boolean   @default(false)

  perfil Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  @@map("formacoes")
}

model Vaga {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  titulo            String
  empresa           String?
  descricaoOriginal String   @map("descricao_original")
  keywords          String[]
  keywordsMatch     String[] @map("keywords_match")
  keywordsFaltantes String[] @map("keywords_faltantes")
  pontuacao         Int
  breakdown         Json
  curriculoJson     Json     @map("curriculo_json")
  criadoEm         DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vagas")
}
